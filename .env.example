POSTGRES_USER=vatdesk
POSTGRES_PASSWORD=vatdesk
POSTGRES_DB=vatdesk

# JWT signing key (HS256, must be >= 32 bytes). docker-compose.yml falls back to a
# demo-only key if this is unset, so `docker compose up` works out of the box for
# reviewers — set a real generated value (e.g. `openssl rand -base64 48`) for anything
# beyond local demo use.
JWT_KEY=
