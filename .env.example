# These are the friendly, flat names docker-compose.yml expects from you locally — it
# translates them into the double-underscore config keys (Jwt__Key,
# ConnectionStrings__Default) the app actually reads. Deploying somewhere that doesn't
# run docker-compose (e.g. Railway) skips that translation, so those double-underscore
# names have to be set directly instead — see docs/DEPLOYMENT.md for the full story.

POSTGRES_USER=vatdesk
POSTGRES_PASSWORD=vatdesk
POSTGRES_DB=vatdesk

# Required. JWT signing key (HS256, must be >= 32 bytes). No default — copy this file to
# .env and generate a real value, e.g.:
#   openssl rand -base64 48
# The app fails fast at startup with a clear error if this is missing or too short.
JWT_KEY=
